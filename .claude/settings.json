{
  "permissions": {
    "allow": [
      "mcp__claude_ai_Atlassian__getAccessibleAtlassianResources",
      "mcp__claude_ai_Atlassian__getJiraIssue",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Read(//c/Users/CHanson/.claude/**)",
      "Bash(gh pr:*)",
      "mcp__plugin_github_github__pull_request_read",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)"
